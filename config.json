{
  "plugins": ["plugins.modbus"],
  "devices": [
    {
      "type": "modbus",
      "name": "Vessel Heat Tape",
      "address": 1,
      "port": "/dev/ttyUSB0",
      "baudrate": 9600,
      "bytesize": 8,
      "parity": "PARITY_NONE",
      "stopbits": 1,
      "timeout": 0.5,
      "mode": "MODE_RTU",
      "clearbuffers": true,
      "queryfile": "./redlion_pxu.register.json",
      "queries":
        ["40001","40002","40017"]
    }
  ]
}
