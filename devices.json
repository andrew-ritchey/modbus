    "baudrate": 9600,
    "bytesize": 8,
    "parity": "PARITY_NONE",
    "stopbits": 1,
    "timeout": 0.5,
    "mode": "MODE_RTU",
    "clearbuffers": true,
    "register": [
      {
        "lookup_value": "40001",
        "register_id": 0,
        "description": "Process Value (PV)",
        "writable": false
      },
      {
