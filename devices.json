{
  "device1": {
    "name": "Vessel Heat Tape",
    "address": 1,
    "port": "/dev/ttyUSB0",
    "baudrate": 9600,
    "bytesize": 8,
    "parity": "PARITY_NONE",
    "stopbits": 1,
    "timeout": 0.5,
    "mode": "MODE_RTU",
    "clearbuffers": true,
    "register": [
      {
        "lookup_value": "40001",
        "register_id": 0,
        "description": "Process Value (PV)",
        "writable": false
      },
      {
        "lookup_value": "40002",
        "register_id": 1,
        "description": "Active Setpoint (SP)",
        "writable": true
      },
      {
        "lookup_value": "40003",
        "register_id": 2,
        "description": "Setpoint 1 (SP1)",
        "writable": true
      }
    ]
  },
  "device2": {
    "name": "Plumbing Heat Tape",
